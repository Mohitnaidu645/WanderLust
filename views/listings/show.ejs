<% layout("/layouts/boilerplate") %>

<div class="container">

    <!-- Listing Title -->
    <div class="text-center mb-4">
        <h2 class="fw-bold"><%= list.title %></h2>
    </div>

    <!-- Listing Card -->
    <div class="card show-card col-lg-8 offset-lg-2 mb-4">
        <img
            src="<%= list.image.url %>"
            class="card-img-top show-img"
            alt="listing image"
        >

        <div class="card-body">

            <p class="mb-3">
                <b>Hosted by:</b>
                <i>@<%= list.owner.username %></i>
            </p>

            <p class="card-text">
                <strong>Description:</strong>
                <%= list.description %>
                <br><br>

                <strong>Price:</strong>
                ₹<%= list.price.toLocaleString("en-IN") %>
                <br>

                <strong>Location:</strong>
                <%= list.location %>
                <br>

                <strong>Country:</strong>
                <%= list.country %>
            </p>

        </div>
    </div>

    <!-- Edit/Delete -->
    <% if(currUser && currUser._id.equals(list.owner._id)){ %>

        <div class="d-flex gap-3 justify-content-center mb-5">

            <form
                method="GET"
                action="/listings/listup/<%= list.id %>"
            >
                <button class="btn btn-dark">
                    Edit
                </button>
            </form>

            <form
                method="POST"
                action="/listings/list/del/<%= list.id %>?_method=DELETE"
            >
                <button class="btn btn-del">
                    Delete
                </button>
            </form>

        </div>

    <% } %>

    <hr>

    <!-- Review Form -->
    <% if(currUser){ %>

        <div class="col-lg-8 offset-lg-2">

            <h3 class="mb-3">
                Leave a Review
            </h3>

            <form
                action="/listings/<%= list.id %>/reviews"
                method="POST"
                class="needs-validation"
                novalidate
            >

                <div class="mb-3">
                    <label class="form-label">
                        Comment
                    </label>

                    <textarea
                        name="review[comment]"
                        rows="4"
                        class="form-control"
                        required
                    ></textarea>

                    <div class="invalid-feedback">
                        Please add a review comment.
                    </div>
                </div>

                <!-- Modern Star Rating -->
                <div class="mb-4">
                    <label class="form-label">
                        Rating
                    </label>

                    <div class="star-rating">

                        <input
                            type="radio"
                            id="star5"
                            name="review[rating]"
                            value="5"
                            required
                        >
                        <label for="star5">★</label>

                        <input
                            type="radio"
                            id="star4"
                            name="review[rating]"
                            value="4"
                        >
                        <label for="star4">★</label>

                        <input
                            type="radio"
                            id="star3"
                            name="review[rating]"
                            value="3"
                        >
                        <label for="star3">★</label>

                        <input
                            type="radio"
                            id="star2"
                            name="review[rating]"
                            value="2"
                        >
                        <label for="star2">★</label>

                        <input
                            type="radio"
                            id="star1"
                            name="review[rating]"
                            value="1"
                        >
                        <label for="star1">★</label>

                    </div>
                </div>

                <button class="btn btn-outline-dark">
                    Submit Review
                </button>

            </form>

        </div>

        <hr class="my-5">

    <% } %>

    <!-- Reviews -->
    <div class="col-lg-8 offset-lg-2">
        <% if (list.reviews.length > 0) { %>
         
        
        <h3 class="mb-4">
            All Reviews
        </h3>

        <% for(let review of list.reviews){ %>

            <div class="card col-5 ms-3 mb-3 p-3">

                <div class="review-header">

                    <div class="review-avatar">
                        <%= review.author.username.charAt(0).toUpperCase() %>
                    </div>

                    <div>

                        <div class="review-user">
                            <%= review.author.username %>
                        </div>

                        <div class="review-stars">

                            <% for(let i=1;i<=5;i++){ %>

                                <% if(i <= review.rating){ %>
                                    ★
                                <% } else { %>
                                    ☆
                                <% } %>

                            <% } %>

                        </div>

                    </div>

                </div>

                <p class="review-comment mt-3">
                    <%= review.comment %>
                </p>

                <% if(currUser && currUser._id.equals(review.author._id)){ %>

                    <form
                        action="/listings/<%= list.id %>/review/<%= review.id %>?_method=DELETE"
                        method="POST"
                    >
                        <button class="btn btn-sm btn-dark">
                            Delete
                        </button>
                    </form>

                <% } %>

            </div>

        <% } %>
        <% } %>
    </div>

</div>